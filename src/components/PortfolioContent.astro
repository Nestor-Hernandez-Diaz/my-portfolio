---
// Este componente incluye el HTML completo de Stitch
// Se renderiza directamente sin procesamiento para mantener fidelidad 100%
---

<!-- Incluir el contenido del body de Stitch tal cual -->
<div id="portfolio-container" set:html={await Astro.slots.render('default')} />

<style is:global>
  /* Asegurar que Tailwind dark mode respete nuestro sistema */
  html.dark [class*="bg-white"],
  html.dark [class*="bg-gray-50"],
  html.dark [class*="text-gray-900"] {
    /* Las clases de Tailwind se invertirán automáticamente */
  }

  /* Importar estilos específicos basado en el tema */
  @layer utilities {
    html:not(.dark) {
      color-scheme: light;
    }
    html.dark {
      color-scheme: dark;
    }
  }
</style>
