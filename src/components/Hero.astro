---
import { Image } from 'astro:assets';
// TODO: Reemplazar profile.svg con tu foto real (hombre, formato cuadrado, mínimo 800x800px)
// Pasos: 1) Copia tu foto a src/assets/profile.jpg  2) Cambia el import a profile.jpg
import profilePlaceholder from '../assets/profile.jpg';
---

<!-- Hero: min-h reducido a ~90vh para que el TechMarquee sea visible sin scroll -->
<section class="flex items-center pt-24 pb-6 px-6 relative z-10" style="min-height: 90vh">
  <div class="max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center">

    <!-- Left: Text Content -->
    <div class="space-y-6">

      <!-- Badge de disponibilidad — color primario azul -->
      <div
        class="inline-flex items-center gap-2 glass-panel px-4 py-2 rounded-full
               text-sm font-medium"
        style="color: var(--text-muted)"
      >
        <!-- Punto azul (#2563EB) en lugar de verde -->
        <span
          class="w-2 h-2 rounded-full animate-pulse flex-shrink-0"
          style="background-color: var(--primary)"
        ></span>
        Disponible para proyectos — 2026
      </div>

      <!-- Heading principal -->
      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight text-gradient">
        Nestor<br />Hernández<br />Díaz
      </h1>

      <!-- Bio profesional -->
      <p class="text-lg max-w-md leading-relaxed" style="color: var(--text-muted)">
        Ingeniero de Sistemas en formación con foco en desarrollo full stack de alto rendimiento.
        Creo soluciones digitales que combinan arquitectura sólida con experiencias de usuario premium.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 pt-2">
        <a href="#projects" class="btn-primary">
          Ver Proyectos
        </a>

        <!-- CV download funcional — el archivo está en public/cv-nestor.pdf -->
        <a
          href="/cv-nestor.pdf"
          download="cv-nestor-hernandez-diaz.pdf"
          class="btn-glass"
          aria-label="Descargar CV de Nestor Hernández Díaz"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg" width="16" height="16"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar CV
        </a>
      </div>
    </div>

    <!-- Right: Profile Card -->
    <div class="flex justify-center">
      <div class="glass-panel rounded-2xl p-6 hover-lift space-y-4 max-w-xs w-full">
        <!--
          TODO: Reemplazar profile.svg con tu foto real.
          Debe ser un hombre, formato cuadrado, mínimo 800x800px, fondo neutro o profesional.
          Ruta: src/assets/profile.jpg (cambiar import arriba también)
        -->
        <Image
          src={profilePlaceholder}
          alt="Nestor Hernández Díaz — Full Stack Developer"
          width={400}
          height={400}
          class="w-full rounded-xl object-cover aspect-square"
          loading="eager"
        />
        <div class="flex items-center gap-2 text-sm" style="color: var(--text-muted)">
          <svg
            xmlns="http://www.w3.org/2000/svg" width="16" height="16"
            viewBox="0 0 24 24" fill="none" stroke="var(--primary)"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          >
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
          <span>Especialización</span>
        </div>
        <p class="font-semibold" style="color: var(--text)">Full Stack Developer</p>
        <p class="text-sm" style="color: var(--text-muted)">Ingeniería de Sistemas e Informática</p>
      </div>
    </div>

  </div>
</section>
