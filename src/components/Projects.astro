---
const projects = [
  {
    category: 'Fintech',
    year: '2025',
    title: 'Fintech Dashboard Pro',
    description:
      'Plataforma de análisis financiero de alto rendimiento con visualización de datos en tiempo real mediante WebSockets de baja latencia. Arquitectura event-driven para procesamiento de transacciones a escala.',
    tags: ['Spring Boot', 'Java', 'PostgreSQL', 'WebSockets'],
    repo: 'https://github.com/nestor-hernandez-diaz',
    image: null, // TODO: Agregar screenshot del proyecto
  },
  {
    category: 'E-commerce',
    year: '2024',
    title: 'Velvet & Gold',
    description:
      'Experiencia de comercio electrónico premium con interfaz de lujo optimizada para conversión. Sistema de inventario en tiempo real y pasarela de pagos integrada.',
    tags: ['Alpine.js', 'Node.js', 'MySQL', 'Express'],
    repo: 'https://github.com/nestor-hernandez-diaz',
    image: null,
  },
  {
    category: 'AI Research',
    year: '2024',
    title: 'Nebula AI Platform',
    description:
      'Plataforma de gestión de datos científicos para investigación en IA. Visualización interactiva de grafos y salas de datos colaborativas con control de acceso granular.',
    tags: ['Python', 'React', 'SQL Server', 'FastAPI'],
    repo: 'https://github.com/nestor-hernandez-diaz',
    image: null,
  },
];
---

<section id="projects" class="py-24 px-6 relative z-10">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color: var(--primary)">
          Proyectos
        </p>
        <h2 class="text-4xl font-bold" style="color: var(--text)">
          Ingeniería & Diseño
        </h2>
      </div>
      <a
        href="https://github.com/nestor-hernandez-diaz"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-1 text-sm font-semibold transition-colors"
        style="color: var(--primary)"
      >
        Ver todos los proyectos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
        </svg>
      </a>
    </div>

    <!-- Projects grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <article class="glass-panel rounded-2xl overflow-hidden hover-lift group flex flex-col">

          <!-- Image placeholder -->
          <div
            class="aspect-video w-full flex items-center justify-center"
            style="background: var(--border)"
          >
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <span class="text-xs font-medium" style="color: var(--text-muted)">
                {/* TODO: Agregar screenshot del proyecto */}
                Preview próximamente
              </span>
            )}
          </div>

          <!-- Content -->
          <div class="p-6 space-y-3 flex flex-col flex-1">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-widest" style="color: var(--primary)">
                {project.category}
              </span>
              <span class="text-xs" style="color: var(--text-muted)">{project.year}</span>
            </div>

            <h3 class="text-xl font-bold" style="color: var(--text)">{project.title}</h3>

            <p class="text-sm leading-relaxed flex-1" style="color: var(--text-muted)">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 pt-1">
              {project.tags.map((tag) => (
                <span
                  class="text-xs glass-panel px-2.5 py-1 rounded-full"
                  style="color: var(--text-muted)"
                >
                  {tag}
                </span>
              ))}
            </div>

            <!-- CTA -->
            <a
              href={project.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-sm font-semibold transition-colors pt-2"
              style="color: var(--primary)"
            >
              Ver repositorio
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>
