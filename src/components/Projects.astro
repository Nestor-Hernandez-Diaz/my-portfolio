---
const projects = [
  {
    category: 'ERP · SaaS',
    year: '2026',
    title: 'New Hype Project',
    description:
      'Frontend monorepo ERP para marca de ropa y accesorios con 3 entornos visuales distintos. Arquitectura modular con paquetes compartidos: tipado TypeScript centralizado, cliente API unificado y sistema de autenticación multi-tenant. 57 commits, 5 colaboradores.',
    tags: ['React 19', 'TypeScript', 'Vite', 'Java', 'Monorepo'],
    repo: 'https://github.com/Nestor-Hernandez-Diaz/New-Hype-Project',
    accent: '#2563EB',
    bgFrom: '#0f172a',
    bgTo: '#1e3a5f',
    icon: `<path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  },
  {
    category: 'Frontend · Wiki',
    year: '2025',
    title: 'GOATs del Fútbol',
    description:
      'Wiki interactiva dedicada a los Greatest Of All Time del fútbol: Messi, Cristiano y Neymar. UI inmersiva con paleta dorada, animaciones CSS avanzadas y diseño responsive desde 320px. Testing automatizado con Playwright y base de datos MySQL.',
    tags: ['HTML5', 'CSS3', 'JavaScript', 'MySQL', 'Playwright'],
    repo: 'https://github.com/Nestor-Hernandez-Diaz/goats-del-futbol',
    accent: '#2563EB',
    bgFrom: '#0f172a',
    bgTo: '#1e3a5f',
    icon: `<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>`,
  },
  {
    category: 'ERP · POS',
    year: '2025',
    title: 'Minimarket Pro',
    description:
      'Sistema SaaS multi-tenant para gestión integral de minimarkets con cumplimiento SUNAT (facturación electrónica). Módulos de POS, inventario con control FEFO, gestión de lotes por empresa y tienda online. Arquitectura multi-tenant con aislamiento por company_id.',
    tags: ['HTML5', 'Tailwind CSS', 'jQuery', 'DataTables', 'SaaS'],
    repo: 'https://github.com/Nestor-Hernandez-Diaz/MINIMARKET-PRO',
    accent: '#2563EB',
    bgFrom: '#0f172a',
    bgTo: '#1e3a5f',
    icon: `<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>`,
  },
  {
    category: 'Backend · Bot',
    year: '2025',
    title: 'Chatbot La Inmaculada',
    description:
      'Chatbot inteligente de WhatsApp para el Supermercado La Inmaculada en Tarapoto. Consultas en tiempo real de stock, precios y ofertas vía WPPConnect. API REST con endpoints de productos y estadísticas. Backend Node.js + Prisma ORM con PostgreSQL en producción.',
    tags: ['Node.js', 'Express', 'WPPConnect', 'Prisma', 'PostgreSQL'],
    repo: 'https://github.com/Nestor-Hernandez-Diaz/chatbot-inmaculada',
    accent: '#2563EB',
    bgFrom: '#0f172a',
    bgTo: '#1e3a5f',
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
];
---

<section id="projects" class="py-24 px-6 relative z-10">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color: var(--primary)">
          Proyectos
        </p>
        <h2 class="text-4xl font-bold" style="color: var(--text)">
          Ingeniería & Diseño
        </h2>
      </div>
      <a
        href="https://github.com/Nestor-Hernandez-Diaz"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-1 text-sm font-semibold transition-colors"
        style="color: var(--primary)"
      >
        Ver todos los proyectos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
        </svg>
      </a>
    </div>

    <!-- Grid: 2 columnas en tablet+, 4 en desktop wide -->
    <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-6">
      {projects.map((project) => (
        <article class="glass-panel rounded-2xl overflow-hidden hover-lift group flex flex-col">

          <!-- Visual identity placeholder — reemplazar con screenshot real -->
          <!--
            TODO: Agregar screenshot de cada proyecto.
            Coloca la imagen en public/projects/{slug}.webp y usa:
            <img src="/projects/{slug}.webp" ... />
          -->
          <div
            class="aspect-video w-full relative overflow-hidden flex items-end p-4"
            style={`background: linear-gradient(135deg, ${project.bgFrom} 0%, ${project.bgTo} 100%)`}
          >
            <!-- Icono grande en fondo decorativo -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="80" height="80"
              viewBox="0 0 24 24"
              fill="none"
              stroke={project.accent}
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="absolute right-3 top-1/2 -translate-y-1/2 opacity-20
                     group-hover:opacity-30 transition-opacity duration-300"
              set:html={project.icon}
            />
            <!-- Badge de categoría superpuesto -->
            <span
              class="relative z-10 text-xs font-bold uppercase tracking-widest
                     px-2.5 py-1 rounded-full"
              style={`background: rgba(0,0,0,0.4); color: ${project.accent};
                      border: 1px solid ${project.accent}40`}
            >
              {project.category}
            </span>
          </div>

          <!-- Content -->
          <div class="p-5 flex flex-col flex-1 gap-3">

            <!-- Título + año -->
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-base font-bold leading-snug" style="color: var(--text)">
                {project.title}
              </h3>
              <span
                class="text-xs flex-shrink-0 font-medium mt-0.5"
                style="color: var(--text-muted)"
              >
                {project.year}
              </span>
            </div>

            <!-- Descripción -->
            <p class="text-xs leading-relaxed flex-1" style="color: var(--text-muted)">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span
                  class="text-xs glass-panel px-2 py-0.5 rounded-full"
                  style="color: var(--text-muted)"
                >
                  {tag}
                </span>
              ))}
            </div>

            <!-- CTA -->
            <a
              href={project.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs font-semibold
                     transition-colors pt-1"
              style={`color: ${project.accent}`}
            >
              <!-- Icono GitHub -->
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                   viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61
                         c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77
                         5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0
                         C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77
                         a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7
                         A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              Ver repositorio
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11"
                   viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>

          </div>
        </article>
      ))}
    </div>

  </div>
</section>
