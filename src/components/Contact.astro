---
const socials = [
  {
    name: 'GitHub',
    url: 'https://github.com/nestor-hernandez-diaz',
    icon: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>`,
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com/in/nestor-hernandez-diaz',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`,
  },
];

// Endpoint Formspree con email directo (no requiere cuenta)
// Si quieres dashboard + analytics: crea cuenta en formspree.io y reemplaza por el ID
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xlgpwgqn';
---

<section id="contact" class="py-24 px-6 relative z-10">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12 space-y-4">
      <p class="text-sm font-semibold uppercase tracking-widest" style="color: var(--primary)">
        Contacto
      </p>
      <h2 class="text-4xl md:text-5xl font-extrabold leading-tight text-gradient">
        Construyamos algo<br />extraordinario.
      </h2>
      <p class="text-lg leading-relaxed max-w-xl mx-auto" style="color: var(--text-muted)">
        Disponible para proyectos freelance, consultoría técnica y oportunidades laborales.
        Si tienes un desafío interesante, hablemos.
      </p>
    </div>

    <!-- Formulario de contacto -->
    <form
      id="contact-form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
      class="glass-panel rounded-2xl p-8 space-y-5"
      novalidate
    >
      <!-- Fila doble: Nombre + Email -->
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="space-y-1.5">
          <label for="nombre" class="text-sm font-medium" style="color: var(--text)">
            Nombre <span style="color: var(--primary)">*</span>
          </label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            required
            placeholder="Tu nombre completo"
            class="w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200
                   border focus:ring-2"
            style="background: var(--surface); border-color: var(--border);
                   color: var(--text); --tw-ring-color: var(--primary)"
          />
        </div>
        <div class="space-y-1.5">
          <label for="email" class="text-sm font-medium" style="color: var(--text)">
            Email <span style="color: var(--primary)">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="tu@correo.com"
            class="w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200
                   border focus:ring-2"
            style="background: var(--surface); border-color: var(--border);
                   color: var(--text); --tw-ring-color: var(--primary)"
          />
        </div>
      </div>

      <!-- Asunto -->
      <div class="space-y-1.5">
        <label for="asunto" class="text-sm font-medium" style="color: var(--text)">
          Asunto <span style="color: var(--primary)">*</span>
        </label>
        <input
          id="asunto"
          name="asunto"
          type="text"
          required
          placeholder="¿En qué te puedo ayudar?"
          class="w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200
                 border focus:ring-2"
          style="background: var(--surface); border-color: var(--border);
                 color: var(--text); --tw-ring-color: var(--primary)"
        />
      </div>

      <!-- Mensaje -->
      <div class="space-y-1.5">
        <label for="mensaje" class="text-sm font-medium" style="color: var(--text)">
          Mensaje <span style="color: var(--primary)">*</span>
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          required
          rows={5}
          placeholder="Cuéntame sobre tu proyecto, idea o consulta..."
          class="w-full rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200
                 border focus:ring-2 resize-none"
          style="background: var(--surface); border-color: var(--border);
                 color: var(--text); --tw-ring-color: var(--primary)"
        ></textarea>
      </div>

      <!-- Submit button -->
      <button
        id="submit-btn"
        type="submit"
        class="w-full flex items-center justify-center gap-3 text-white font-semibold
               py-3.5 rounded-xl transition-all duration-200 text-base"
        style="background-color: var(--primary)"
      >
        <svg id="submit-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        <span id="submit-text">Iniciar Conversación</span>
        <!-- Spinner (oculto por defecto) -->
        <svg id="submit-spinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg"
             width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
      </button>

      <!-- Mensajes de estado (ocultos por defecto) -->
      <div
        id="form-success"
        class="hidden rounded-xl px-5 py-4 text-sm font-medium text-center
               transition-all duration-300"
        style="background: rgba(37,99,235,0.1); border: 1px solid rgba(37,99,235,0.3);
               color: var(--primary)"
        role="alert"
      >
        ✓ Mensaje enviado exitosamente. ¡Te contactaré pronto!
      </div>

      <div
        id="form-error"
        class="hidden rounded-xl px-5 py-4 text-sm font-medium text-center
               transition-all duration-300"
        style="background: rgba(220,38,38,0.08); border: 1px solid rgba(220,38,38,0.3);
               color: #ef4444"
        role="alert"
      >
        ✕ Ocurrió un error al enviar el mensaje. Por favor intenta de nuevo.
      </div>
    </form>

    <!-- Social links -->
    <div class="flex justify-center gap-4 mt-8">
      {socials.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={social.name}
          class="glass-panel p-3 rounded-full hover-lift transition-colors"
          style="color: var(--text-muted)"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18" height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={social.icon}
          />
        </a>
      ))}
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitText = document.getElementById('submit-text');
  const submitIcon = document.getElementById('submit-icon');
  const submitSpinner = document.getElementById('submit-spinner');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validación HTML5
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Estado: cargando
    if (submitBtn) submitBtn.disabled = true;
    submitText && (submitText.textContent = 'Enviando...');
    submitIcon?.classList.add('hidden');
    submitSpinner?.classList.remove('hidden');
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        // Éxito
        form.reset();
        successMsg?.classList.remove('hidden');
        // Scroll suave al mensaje
        successMsg?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      // Restaurar botón
      if (submitBtn) submitBtn.disabled = false;
      submitText && (submitText.textContent = 'Iniciar Conversación');
      submitIcon?.classList.remove('hidden');
      submitSpinner?.classList.add('hidden');
    }
  });

  // Focus ring con color primario en CSS custom properties
  const inputs = form?.querySelectorAll('input, textarea');
  inputs?.forEach((el) => {
    el.addEventListener('focus', () => {
      (el as HTMLElement).style.borderColor = 'var(--primary)';
    });
    el.addEventListener('blur', () => {
      (el as HTMLElement).style.borderColor = 'var(--border)';
    });
  });
</script>
